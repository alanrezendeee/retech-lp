---
interface Props { waUrl: string; }
const { waUrl } = Astro.props;
const services = [
  {
    icon: `<rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
    title: 'Desenvolvimento de Software',
    desc: 'Sistemas web, APIs, backends robustos e frontends performáticos. Do MVP à plataforma de escala, com código limpo e testado.',
    tags: ['Node.js', 'TypeScript', 'React', 'PostgreSQL'],
    color: 'text-blue-400',
    bg: 'bg-blue-500/10 border-blue-500/20',
  },
  {
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="1.5"/><polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="22.08" x2="12" y2="12" stroke="currentColor" stroke-width="1.5"/>`,
    title: 'Arquitetura de Sistemas',
    desc: 'Design de sistemas distribuídos, microservices, event-driven e serverless. Arquitetura que suporta crescimento sem refatoração total.',
    tags: ['DDD', 'Microservices', 'Event-driven', 'AWS'],
    color: 'text-purple-400',
    bg: 'bg-purple-500/10 border-purple-500/20',
  },
  {
    icon: `<path d="M8 9l3 3-3 3M13 15h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>`,
    title: 'Integração e APIs',
    desc: 'Conexão de sistemas legados, ERPs, CRMs e plataformas externas. APIs RESTful, GraphQL e gRPC bem documentadas e seguras.',
    tags: ['REST', 'GraphQL', 'Webhooks', 'OpenAPI'],
    color: 'text-teal-400',
    bg: 'bg-teal-500/10 border-teal-500/20',
  },
  {
    icon: `<path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: 'Automação com IA',
    desc: 'Workflows inteligentes, agents LLM, processamento de documentos e automação de processos com n8n, Langchain e APIs de IA.',
    tags: ['n8n', 'LangChain', 'OpenAI', 'Agents'],
    color: 'text-[#00FF88]',
    bg: 'bg-[#00FF88]/10 border-[#00FF88]/20',
    featured: true,
  },
  {
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
    title: 'Consultoria Técnica',
    desc: 'Review de arquitetura, code review, escolha de stack, due diligence técnico e mentoria de times de engenharia.',
    tags: ['Code Review', 'Arquitetura', 'Stack', 'Mentoria'],
    color: 'text-amber-400',
    bg: 'bg-amber-500/10 border-amber-500/20',
  },
];
---

<section id="servicos" class="pt-16 pb-24 bg-[#0d0d0d]" aria-labelledby="services-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14 fade-in">
      <span class="badge-neon mb-6 inline-flex">Serviços</span>
      <h2 id="services-heading" class="font-display font-bold text-3xl sm:text-4xl md:text-5xl leading-tight mb-4">
        O que a The Retech<br />
        <span class="neon-text">constrói para você</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-xl">
        Da ideia ao produto em produção — com engenharia sólida em cada etapa.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <div
          class={`bg-[#111111] border rounded-2xl p-7 card-hover fade-in relative overflow-hidden ${s.featured ? 'border-[#00FF88]/25 bg-[#00FF88]/5' : 'border-[#1e1e1e]'}`}
          style={`animation-delay: ${i * 0.08}s`}
        >
          {s.featured && (
            <div class="absolute top-4 right-4">
              <span class="text-[10px] font-semibold text-[#00FF88] bg-[#00FF88]/10 border border-[#00FF88]/20 px-2 py-1 rounded-full uppercase tracking-wider">
                Em alta
              </span>
            </div>
          )}

          <!-- Number watermark -->
          <span class="absolute top-3 right-5 font-display font-bold text-6xl leading-none select-none pointer-events-none text-white/[0.03]" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>

          <div class={`w-12 h-12 rounded-xl border flex items-center justify-center mb-5 ${s.bg}`}>
            <svg viewBox="0 0 24 24" fill="none" class={`w-6 h-6 ${s.color}`} aria-hidden="true">
              <Fragment set:html={s.icon} />
            </svg>
          </div>

          <h3 class="font-display font-bold text-xl text-white mb-3">{s.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-5">{s.desc}</p>

          <div class="flex flex-wrap gap-2">
            {s.tags.map(tag => (
              <span class={`px-2.5 py-1 rounded-md text-xs font-medium border ${s.bg} ${s.color}`}>
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}

      <!-- CTA card -->
      <a
        class="bg-[#111111] border-2 border-dashed border-[#1e1e1e] hover:border-[#00FF88]/30 rounded-2xl p-7 flex flex-col items-center justify-center text-center gap-4 transition-colors duration-200 cursor-pointer group fade-in no-underline"
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Falar sobre seu projeto no WhatsApp"
      >
        <div class="w-14 h-14 rounded-full border border-[#1e1e1e] group-hover:border-[#00FF88]/30 flex items-center justify-center transition-colors duration-200">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-gray-500 group-hover:text-[#00FF88] transition-colors duration-200" aria-hidden="true">
            <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="font-display font-semibold text-white text-lg">Tem um projeto?</p>
          <p class="text-sm text-gray-400 mt-1">Vamos conversar sobre sua necessidade</p>
        </div>
        <span class="text-sm font-medium text-[#00FF88] group-hover:underline">Falar com especialista →</span>
      </a>
    </div>
  </div>
</section>
